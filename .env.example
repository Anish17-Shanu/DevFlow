DEVFLOW_ENVIRONMENT=development
DEVFLOW_APP_VERSION=1.0.0
DEVFLOW_DATABASE_URL=sqlite+aiosqlite:///./devflow.db
DEVFLOW_WORKER_COUNT=4
DEVFLOW_WORKER_POLL_INTERVAL_MS=250
DEVFLOW_WORKER_HEARTBEAT_INTERVAL_SECONDS=5
DEVFLOW_INLINE_WORKERS_ENABLED=true
DEVFLOW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEVFLOW_DOCS_ENABLED=true
DEVFLOW_LOG_LEVEL=INFO
DEVFLOW_QUEUE_LEASE_SECONDS=30
DEVFLOW_REALTIME_POLL_INTERVAL_MS=1000
